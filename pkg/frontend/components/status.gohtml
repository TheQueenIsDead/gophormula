{{define "status"}}
<span id="status-time">——:——:——</span>
<nav class="status-bar">
    <span id="status-session" class="status-item"></span>
    <span class="status-item"><span class="status-label">Remaining</span><span id="status-remaining"></span></span>
    <span class="status-item"><span class="status-label">Lap</span><span id="status-lap">— / —</span></span>
    <span class="status-item"><span class="status-label">Track</span><span id="status-track">—</span></span>
    <span class="status-item"><span class="status-label">Weather</span><span id="status-weather">—</span></span>
</nav>
{{end}}